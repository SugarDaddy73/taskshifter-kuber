{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware": "None",
      "Microsoft.EntityFrameworkCore.Database.Command": "None"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server={Host}; Database={DbName}; User ID={DbUsername}; Password={DbPassword}"
  },
  "Authentication": {
    "Tokens": {
      "AccessTokenSigningKey": "super_secret_key_that_is_at_least_16_chars",
      "AccessTokenExpiryInSeconds": "3600"
    }
  },
  "AllowedHosts": "*"
}
